# Recommended default (production only):
PAGER_TELEMETRY_URL="https://rccolamachine.com/api/pager/telemetry"

# Optional fan-out for temporary local testing:
# PAGER_TELEMETRY_URLS="https://rccolamachine.com/api/pager/telemetry,http://192.168.1.66:3000/api/pager/telemetry"
PAGER_TELEMETRY_SECRET="replace-with-telemetry-secret"
# Optional exact file path (if set and exists, this is used first):
# MMDVM_LOG_FILE="/var/log/pi-star/MMDVM-2026-03-09.log"

# Recommended for daily log rollover:
MMDVM_LOG_GLOB="/var/log/pi-star/MMDVM-*.log"
MMDVM_LOG_SWITCH_INTERVAL_SEC="30"
# Optional regex overrides for your local Pi-Star log format:
# GATEWAY_RECEIVED_REGEX="DAPNET|POCSAG.*(queue|queued|received)"
# MMDVM_TX_STARTED_REGEX="POCSAG.*(tx|transmit|sending|start)"
# MMDVM_TX_COMPLETED_REGEX="POCSAG.*(complete|completed|sent|finish|end|stop)"
