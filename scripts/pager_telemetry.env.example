# Recommended default (production only):
PAGER_TELEMETRY_URL="https://rccolamachine.com/api/pager/telemetry"

# NOTE:
# On Pi-Star, "localhost" points to Pi-Star itself (not your dev machine).
# For local dev testing, use your dev machine LAN IP, e.g.:
# PAGER_TELEMETRY_URL="http://192.168.1.66:3000/api/pager/telemetry"
#
# Optional fan-out for temporary local testing:
# PAGER_TELEMETRY_URLS="https://rccolamachine.com/api/pager/telemetry,http://192.168.1.66:3000/api/pager/telemetry"
PAGER_TELEMETRY_SECRET="replace-with-telemetry-secret"
# Optional exact file path (if set and exists, this is used first):
# MMDVM_LOG_FILE="/var/log/pi-star/MMDVM-2026-03-09.log"
# Optional exact DAPNET gateway file (if set and exists, used first):
# DAPNET_LOG_FILE="/var/log/pi-star/DAPNETGateway-2026-03-09.log"

# Recommended for daily log rollover:
MMDVM_LOG_GLOB="/var/log/pi-star/MMDVM-*.log"
# Include DAPNET Gateway Activity logs to capture message text when available:
DAPNET_LOG_GLOB="/var/log/pi-star/DAPNETGateway-*.log"
MMDVM_LOG_SWITCH_INTERVAL_SEC="30"
# Optional additional comma-separated globs:
# PAGER_EXTRA_LOG_GLOBS="/var/log/pi-star/DAPNET-*.log,/var/log/pi-star/*POCSAG*.log"
# Logging mode: 0 = concise stage logs (recommended), 1 = full payload + raw line debug.
PAGER_TELEMETRY_LOG_FULL_PAYLOAD="0"
# Optional noise controls:
# GATEWAY_DUPLICATE_WINDOW_SEC="30"
# MMDVM_TX_STARTED_COOLDOWN_SEC="3"
# Optional regex overrides for your local Pi-Star log format:
# GATEWAY_RECEIVED_REGEX="DAPNET|POCSAG.*(queue|queued|received)"
# MMDVM_TX_STARTED_REGEX="POCSAG.*(tx|transmit|transmitted|sending|start|starting)"
# MMDVM_TX_COMPLETED_REGEX="POCSAG.*(complete|completed|sent|finish|end|stop)"
# DAPNET gateway lines (from DAPNETGateway-*.log) that should map to gateway_received:
# DAPNET_GATEWAY_REGEX="Queueing message|Sending message in slot"
# Bridge automatically appends parsed metadata when available:
# detail "target:<callsign-or-capcode> text:\"<message>\" source:<file>"
